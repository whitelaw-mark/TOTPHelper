<Window x:Class="LoginClipboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoginClipboardApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="250" Width="750">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="20,5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
        <Style TargetType="Button" >
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="MaxHeight" Value="25"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="MaxWidth" Value="100"/>
            <Setter Property="BorderBrush" Value="Black" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label Content="UserName:" />
        <TextBox Grid.Column="1" Text="{Binding Path=UserName}"/>
        <Border Grid.Row="0" Grid.Column="2" >
            <Button Grid.Column="2" Command="{Binding Path=CopyUserNameCommand}" Content="Copy" />
        </Border>
        
        <Label Grid.Row="1" Content="Password:" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Path=Password}"/>
        <Border Grid.Row="1" Grid.Column="2" >
            <Button  Command="{Binding Path=CopyPasswordCommand}" Content="Copy" />
       </Border>

        <Label Grid.Row="2" Content="TOTP:" />
        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Path=TOTP}" />
        <Border Grid.Row="2" Grid.Column="2" >
            <Button  Command="{Binding Path=CopyTOTPCommand}" Content="Copy" />
        </Border>

        <Label Grid.Row="3" Content="Buffer:" />
        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Path=ClipboardContent, NotifyOnSourceUpdated=True, UpdateSourceTrigger=PropertyChanged}"/>
        <Border Grid.Row="3" Grid.Column="2" >
            <Button Grid.Column="2" Command="{Binding Path=CopyClipboardCommand}" Content="Copy" />
        </Border>

    </Grid>
</Window>
