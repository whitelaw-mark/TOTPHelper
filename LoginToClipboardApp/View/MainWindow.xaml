<Window x:Class="LoginClipboardApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoginClipboardApp"
        mc:Ignorable="d"
        Title="User Credentials Clipboard Helper" Height="280" Width="750" ResizeMode="NoResize" Topmost="True">

    <TabControl ItemsSource="{Binding Path=UserCredentials}" DisplayMemberPath="UserName" SelectedItem="{Binding Path=CurrentTab}" >
    </TabControl>

</Window>
